# Database (Postgres - Prisma)
# Get from secret vault
DATABASE_URL="postgres://user:password@host:port/database?sslmode=verify-full"

# JWT Secret
# Get from secret vault - must be 64-character hex string
JWT_SECRET="your_jwt_secret_here"

# Environment
NODE_ENV=development

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# Audit Logging
AUDIT_LOG_ENDPOINT=https://your-audit-service.com/logs
AUDIT_LOG_RETENTION_DAYS=90

# Error Tracking - Sentry
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
ERROR_TRACKING_ENDPOINT=https://your-error-service.com/errors
